# Engine configuration
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# API authentication — set a strong random secret; leave empty to disable (dev only)
API_KEY=

# Rate limiting per IP on moderation endpoints (e.g. "60/minute", "10/second")
RATE_LIMIT=60/minute

# i18n — comma-separated list of enabled language pack codes
ENABLED_LANGUAGES=en,de

# Moderation profile — sets all thresholds at once (individual vars below still override)
# Options: minors_strict | default | permissive
MODERATION_PROFILE=default

# Thresholds (0.0 - 1.0) — content above these scores triggers "delete"
# Leave commented out to use the profile defaults above.
THRESHOLD_VIOLENCE=0.6
THRESHOLD_SEXUAL_VIOLENCE=0.6
THRESHOLD_NSFW=0.6
THRESHOLD_DEEPFAKE=0.8
THRESHOLD_CYBERBULLYING=0.6

# ---------------------------------------------------------------------------
# Deepfake detection
# ---------------------------------------------------------------------------
# Provider: local | sightengine | api | stub
# "local" runs inference on-device (privacy-first, no data leaves the server)
# "sightengine" or "api" sends face crops to external services (GDPR warning!)
# "stub" returns a fixed score of 0.05 (for CI/testing without models)
DEEPFAKE_PROVIDER=local

# Local provider: path to ONNX model file (auto-downloaded if empty)
DEEPFAKE_MODEL_PATH=

# SightEngine cloud provider (only if DEEPFAKE_PROVIDER=sightengine)
# WARNING: face images will be sent to SightEngine's servers
SIGHTENGINE_API_USER=
SIGHTENGINE_API_SECRET=

# Generic API provider (only if DEEPFAKE_PROVIDER=api)
# WARNING: face images will be sent to this endpoint
DEEPFAKE_API_URL=
DEEPFAKE_API_KEY=
DEEPFAKE_API_SCORE_PATH=score

# ---------------------------------------------------------------------------
# Video processing
# ---------------------------------------------------------------------------
# Seconds between sampled frames
FRAME_INTERVAL=2.0
# Maximum number of frames to analyse per video
MAX_FRAMES=10
# Maximum video duration in seconds (longer videos are rejected)
MAX_VIDEO_DURATION=300

# GDPR / persistence
# SQLite (default, zero-config) or PostgreSQL: postgresql+asyncpg://user:pw@host/db
DATABASE_URL=sqlite+aiosqlite:///./deepfake_guardian.db
# Secret salt for hashing user/group IDs — set a strong random value in production
GDPR_SALT=change-me-in-production
# Days before moderation events are automatically deleted (Article 5(1)(e))
DATA_RETENTION_DAYS=30
